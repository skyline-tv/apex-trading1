OPENAI_API_KEY=your_openai_api_key_here
# Optional: override model (default: gpt-4.1-mini)
OPENAI_MODEL=gpt-4.1-mini
# Optional: protects mutating API endpoints when set.
APEX_API_TOKEN=change_me_to_a_long_random_secret
# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Use persistent disk path in production (e.g., /var/data/trades.db on Render).
TRADES_DB_PATH=backend/trades.db
